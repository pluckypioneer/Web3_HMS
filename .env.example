# 生产环境配置文件模板
# 请复制此文件为 .env 并填入实际的生产环境值

# 基础配置
FLASK_ENV=production
SECRET_KEY=your-very-secure-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# 数据库配置
POSTGRES_PASSWORD=your-secure-postgres-password
DATABASE_URL=postgresql://hms_user:your-secure-postgres-password@postgres:5432/hms_db

# Redis配置
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://:your-secure-redis-password@redis:6379/0

# Web3配置
WEB3_PROVIDER_URL=http://ganache:8545
MEDICAL_RECORD_HASH_ADDRESS=0x...
ACCESS_CONTROL_ADDRESS=0x...
DRUG_TRACE_ADDRESS=0x...

# IPFS配置
IPFS_URL=http://ipfs:5001

# CORS配置（生产环境应该限制具体域名）
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 邮件配置
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Celery配置
CELERY_BROKER_URL=redis://:your-secure-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:your-secure-redis-password@redis:6379/1